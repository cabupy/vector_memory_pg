# Conexión a PostgreSQL (con pgvector instalado)
# Con Docker (docker-compose.yml):
DATABASE_URL=postgres://vector:vector@localhost:5432/vector_memory
# Con PostgreSQL local propio:
# DATABASE_URL=postgresql://usuario:password@localhost:5435/vector_memory_db

# OpenAI API Key — para generar embeddings con text-embedding-3-small
OPENAI_API_KEY=tu_openai_api_key_aqui

# Rutas locales del agente (ajustar según tu setup)
SESSIONS_DIR=/ruta/a/tus/sesiones
MEMORY_DIR=/ruta/a/tu/carpeta/memory
MEMORY_FILE=/ruta/a/tu/MEMORY.md

# Docker (opcional — sobreescribe los defaults del docker-compose.yml)
# POSTGRES_USER=vector
# POSTGRES_PASSWORD=vector
# POSTGRES_DB=vector_memory
# POSTGRES_PORT=5432
# API_PORT=3010
